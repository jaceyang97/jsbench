# jsbench CODEX agent container: OpenAI Codex CLI (pinned) + offline scientific
# stack. Mirror of the Claude agent image (docker/Dockerfile) so the ONLY
# difference between the two harnesses is the agent scaffold itself, not the
# runtime environment. No direct egress; all traffic goes through the codex
# allowlist proxy sidecar (allows api.openai.com, blocks solution sources).
FROM node:20-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Pinned harness version — keep in sync with config/bench.yaml (codex_version).
RUN npm install -g @openai/codex@0.145.0

# Identical solver stack to the Claude image (harness/prompts.py claims).
RUN pip3 install --break-system-packages --no-cache-dir \
        numpy scipy sympy pandas z3-solver ortools networkx pillow matplotlib

ENV PYTHONIOENCODING=utf-8 \
    CODEX_DISABLE_UPDATE_CHECK=1

# Python-side harness deps (the codex runner executes inside the container too).
RUN pip3 install --break-system-packages --no-cache-dir \
        openai requests beautifulsoup4 lxml loguru pyyaml

WORKDIR /bench
# repo is bind-mounted at /bench by docker-compose
